---
interface Props { headings: { depth: number; slug: string; text: string }[] }
const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2);
---
{items.length > 2 && (
  <nav class="toc" aria-label="Table of contents">
    <p class="toc-title">On this page</p>
    <ul>
      {items.map((h) => (
        <li><a href={`#${h.slug}`}>{h.text}</a></li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc {
    position: sticky; top: 4.5rem; max-height: calc(100vh - 6rem); overflow-y: auto;
    width: 220px; flex-shrink: 0; font-size: 0.83rem; padding-left: 1rem;
    border-left: 1px solid var(--border);
  }
  .toc-title {
    text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.72rem;
    color: var(--text-muted); margin: 0 0 0.75rem;
  }
  ul { list-style: none; margin: 0; padding: 0; }
  li { margin: 0.4rem 0; }
  a {
    color: var(--text-muted); display: block; line-height: 1.4;
    transition: color 0.12s ease;
  }
  a:hover, a:focus-visible { color: var(--accent); text-decoration: none; }
  @media (max-width: 1100px) { .toc { display: none; } }
</style>
