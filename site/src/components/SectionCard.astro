---
interface Props { dir: string; title: string; docCount: number; fresh: boolean; checkTotal?: number }
const { dir, title, docCount, fresh, checkTotal = 0 } = Astro.props;
const num = dir.slice(0, 2);
---
<a class="card" href={`/${dir}/`}>
  <span class="num">{num}</span>
  <span class="card-title">{title}</span>
  <span class="meta">
    {docCount} docs
    {fresh && <span class="fresh-dot" title="Recently updated">⚡</span>}
    {checkTotal > 0 && (
      <span
        class="card-progress"
        role="img"
        aria-label={`${title} progress`}
        data-progress-ring
        data-progress-prefix={`${dir}/`}
        data-progress-total={String(checkTotal)}
      >
        <span data-ring-label>0%</span>
      </span>
    )}
  </span>
</a>

<style>
  .card {
    display: flex; flex-direction: column; gap: 0.5rem;
    border: 1.5px solid var(--border); border-radius: var(--radius-lg);
    padding: 1.1rem 1.2rem; background: var(--surface); color: var(--text);
    transition: border-color 120ms ease, transform 120ms ease, box-shadow 120ms ease;
  }
  .card:hover {
    border-color: var(--accent); transform: translateY(-2px); text-decoration: none;
    box-shadow: 0 6px 18px -12px color-mix(in srgb, var(--text) 40%, transparent);
  }
  /* Play marker: the section's number as an O on the board. */
  .num {
    font-family: var(--font-display); font-size: 0.8rem; color: var(--accent);
    border: 2px solid var(--accent); border-radius: 999px;
    width: 2rem; height: 2rem; display: grid; place-items: center;
  }
  .card:hover .num { color: var(--accent-2); border-color: var(--accent-2); }
  .card-title { font-weight: 700; letter-spacing: -0.01em; font-size: 1.02rem; }
  .meta { font-size: 0.8rem; color: var(--text-muted); display: flex; gap: 0.4rem; align-items: center; font-family: var(--font-mono); }
</style>
