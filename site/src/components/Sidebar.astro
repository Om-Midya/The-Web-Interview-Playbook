---
import { sectionOf, sectionTitle, sortDocs, isSectionReadme, allSectionDirs } from '../lib/content';
import { withBase } from '../lib/base';

interface Props {
  docs: { id: string; title: string }[];
  currentId?: string;
  currentSection?: string;
}
const { docs, currentId, currentSection } = Astro.props;
const sections = allSectionDirs(docs.map((d) => d.id));
const byId = new Map(docs.map((d) => [d.id, d]));
---
<aside class="sidebar">
  <nav aria-label="All sections">
    {sections.map((s) => {
      const ids = sortDocs(
        docs.filter((d) => sectionOf(d.id) === s && !isSectionReadme(d.id)).map((d) => d.id)
      );
      return (
        <details open={s === currentSection}>
          <summary><a href={withBase(`/${s}/`)}>{sectionTitle(s)}</a></summary>
          <ul>
            {ids.map((id) => (
              <li>
                <a href={withBase(`/${id}/`)} aria-current={id === currentId ? 'page' : undefined}>
                  {byId.get(id)?.title ?? id}
                </a>
              </li>
            ))}
          </ul>
        </details>
      );
    })}
  </nav>
</aside>

<style>
  .sidebar {
    width: 260px; flex-shrink: 0; border-right: 1px solid var(--border);
    padding: 1.25rem 0.9rem; position: sticky; top: 3.2rem;
    height: calc(100vh - 3.2rem); overflow-y: auto; font-size: 0.86rem;
  }
  summary { cursor: pointer; padding: 0.3rem 0.4rem; font-weight: 600; list-style: none; }
  summary::before { content: '▸ '; color: var(--text-muted); font-size: 0.7rem; }
  details[open] summary::before { content: '▾ '; }
  summary a { color: var(--text); }
  ul { list-style: none; margin: 0 0 0.5rem; padding: 0 0 0 1.1rem; }
  li a {
    display: block; padding: 0.22rem 0.5rem; color: var(--text-muted); border-radius: 6px;
  }
  li a:hover { color: var(--text); background: var(--surface-2); text-decoration: none; }
  li a[aria-current='page'] { color: var(--accent); background: var(--surface-2); font-weight: 600; }
  @media (max-width: 900px) { .sidebar { display: none; } }
</style>
