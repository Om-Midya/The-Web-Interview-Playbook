---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FreshnessBadge from '../components/FreshnessBadge.astro';
import StatusBanner from '../components/StatusBanner.astro';
import TocNav from '../components/TocNav.astro';
import Sidebar from '../components/Sidebar.astro';
import { sectionOf, sectionTitle, extractTitle, sortDocs, isSectionReadme } from '../lib/content';
import { getLastCommitISO } from '../lib/freshness';
import { withBase } from '../lib/base';
import '../styles/prose.css';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs
    .filter((d) => d.id !== 'readme' && !isSectionReadme(d.id))
    .map((doc) => ({
      params: { slug: doc.id === 'roadmap' ? 'roadmap-source' : doc.id },
      props: { doc, all: docs },
    }));
}

const { doc, all } = Astro.props;
const title = extractTitle(doc.body ?? '', doc.id);
const section = sectionOf(doc.id);
const iso = doc.filePath ? getLastCommitISO(doc.filePath) : null;

const siblings = section
  ? sortDocs(all.filter((d) => sectionOf(d.id) === section && !isSectionReadme(d.id)).map((d) => d.id))
  : [];
const idx = siblings.indexOf(doc.id);
const prev = idx > 0 ? siblings[idx - 1] : null;
const next = idx >= 0 && idx < siblings.length - 1 ? siblings[idx + 1] : null;
const titleFor = (id: string) => {
  const e = all.find((d) => d.id === id);
  return e ? extractTitle(e.body ?? '', e.id) : id;
};

const { Content, headings } = await render(doc);
const navDocs = all.map((d) => ({ id: d.id, title: extractTitle(d.body ?? '', d.id) }));
const tocItems = headings.filter((h) => h.depth === 2);
---
<BaseLayout title={title} searchable={doc.id !== 'roadmap'}>
  <Sidebar slot="sidebar" docs={navDocs} currentId={doc.id} currentSection={section ?? undefined} />
  <div class="doc-shell">
    {/* Inline collapsible TOC — shown on tablets and below */}
    {tocItems.length > 2 && (
      <details class="toc-inline">
        <summary>On this page</summary>
        <ul>
          {tocItems.map((h) => (
            <li><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ul>
      </details>
    )}
    <article class="prose">
      {section && (
        <p class="crumbs">
          <a href={withBase(`/${section}/`)}>{sectionTitle(section)}</a>
          {' '}<FreshnessBadge iso={iso} uid={doc.id} />
        </p>
      )}
      {doc.data.status === 'updating' && <StatusBanner />}
      <Content />
      <nav class="pager">
        {prev ? <a class="pager-link" href={withBase(`/${prev}/`)}>← {titleFor(prev)}</a> : <span />}
        {next ? <a class="pager-link next" href={withBase(`/${next}/`)}>{titleFor(next)} →</a> : <span />}
      </nav>
    </article>
    <TocNav headings={headings} />
  </div>
</BaseLayout>

<style>
  .doc-shell { display: flex; gap: 2rem; justify-content: center; }
  .crumbs { display: flex; align-items: center; gap: 0.75rem; font-size: 0.85rem; margin-bottom: 0.5rem; }
  .crumbs a { color: var(--text-muted); font-weight: 500; }
  .crumbs a:hover { color: var(--accent); text-decoration: none; }
  .pager { display: flex; justify-content: space-between; gap: 1rem; margin-top: 3.5rem; }
  .pager-link {
    display: block; border: 1px solid var(--border); border-radius: var(--radius);
    padding: 0.7rem 1rem; font-size: 0.88rem; max-width: 45%; color: var(--text);
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .pager-link.next { text-align: right; margin-left: auto; }
  .pager-link:hover, .pager-link:focus-visible { border-color: var(--accent); color: var(--accent); text-decoration: none; }

  /* Inline collapsible TOC — visible only on tablets and below */
  .toc-inline {
    display: none;
    font-size: 0.85rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface-2);
    padding: 0.5rem 0.8rem;
    margin-bottom: 0.5rem;
    max-width: var(--content-width);
    width: 100%;
  }
  .toc-inline summary {
    cursor: pointer;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.72rem;
    color: var(--text-muted);
    padding: 0.15rem 0;
    list-style: none;
  }
  .toc-inline summary::before { content: '▸ '; font-size: 0.7rem; }
  .toc-inline[open] summary::before { content: '▾ '; }
  .toc-inline ul { list-style: none; margin: 0.5rem 0 0; padding: 0; display: grid; gap: 0.2rem; }
  .toc-inline li { margin: 0; }
  .toc-inline a {
    display: block; padding: 0.35rem 0.5rem; color: var(--text-muted);
    border-radius: 6px; transition: color 0.12s ease;
  }
  .toc-inline a:hover, .toc-inline a:focus-visible {
    color: var(--text); background: var(--surface); text-decoration: none;
  }
  @media (max-width: 1300px) {
    .toc-inline { display: block; }
  }

  /* Responsive pagination links on narrow screens */
  @media (max-width: 600px) {
    .pager { flex-direction: column; gap: 0.5rem; }
    .pager-link { max-width: 100%; }
    .pager-link.next { text-align: left; margin-left: 0; }
  }
</style>
