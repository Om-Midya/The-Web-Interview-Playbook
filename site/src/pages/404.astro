---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/base';
---
<BaseLayout title="Out of bounds" description="404 — this route isn't on the board." searchable={false}>
  <div class="nf">
    <svg class="nf-mark" viewBox="0 0 120 72" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <circle cx="10" cy="58" r="5" />
      <path class="nf-route" d="M18 54 C 40 20, 62 50, 86 28" stroke-dasharray="6 5" />
      <path class="nf-x" d="M90 20 l14 14 m0 -14 l-14 14" stroke-width="3" />
    </svg>
    <p class="nf-eyebrow">Out of bounds</p>
    <h1 class="display nf-title">404 — busted play</h1>
    <p class="nf-copy">This route isn't on the board. It may have moved, or it never existed.</p>
    <div class="nf-actions">
      <a class="nf-btn is-primary" href={withBase('/')}>Back to the board</a>
      <a class="nf-btn" href={withBase('/roadmap/')}>See the game plan</a>
    </div>
    <p class="nf-hint">Or press <kbd>⌘K</kbd> to search every play.</p>
  </div>
</BaseLayout>

<style>
  .nf { max-width: 34rem; margin: 8vh auto 0; text-align: center; }
  .nf-mark { width: 9rem; max-width: 60%; color: var(--text-muted); margin-bottom: 1rem; }
  .nf-route { stroke: var(--accent-2); }
  .nf-x { stroke: var(--accent); }
  .nf-eyebrow {
    font-family: var(--font-mono); font-size: 0.78rem; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent-2);
    margin: 0 0 0.5rem;
  }
  .nf-title { font-size: clamp(1.6rem, 4vw, 2.3rem); margin: 0 0 0.75rem; }
  .nf-copy { color: var(--text-muted); margin: 0 0 1.5rem; }
  .nf-actions { display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap; }
  .nf-btn {
    border: 1px solid var(--border); border-radius: var(--radius);
    padding: 0.55rem 1rem; color: var(--text); font-size: 0.9rem;
  }
  .nf-btn:hover, .nf-btn:focus-visible { border-color: var(--accent); color: var(--accent); text-decoration: none; }
  .nf-btn.is-primary { background: var(--accent); border-color: var(--accent); color: var(--accent-contrast); }
  .nf-btn.is-primary:hover, .nf-btn.is-primary:focus-visible { opacity: 0.9; color: var(--accent-contrast); }
  .nf-hint { margin-top: 1.25rem; font-size: 0.82rem; color: var(--text-muted); }
  .nf-hint kbd {
    font-family: var(--font-mono); border: 1px solid var(--border);
    border-radius: 4px; padding: 0.05rem 0.4rem; background: var(--surface-2);
  }
</style>
