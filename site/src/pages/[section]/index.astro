---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FreshnessBadge from '../../components/FreshnessBadge.astro';
import StatusBanner from '../../components/StatusBanner.astro';
import Sidebar from '../../components/Sidebar.astro';
import { sectionOf, sectionTitle, extractTitle, sortDocs, isSectionReadme, allSectionDirs } from '../../lib/content';
import { getLastCommitISO } from '../../lib/freshness';
import { withBase } from '../../lib/base';
import WidgetHost from '../../widgets/WidgetHost';
import { SECTION_WIDGETS, SECTION_TOOLS } from '../../widgets/manifest';
import '../../styles/prose.css';
import '../../styles/widgets.css';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return allSectionDirs(docs.map((d) => d.id)).map((section) => ({
    params: { section },
    props: { section, docs },
  }));
}

const { section, docs } = Astro.props;
const readme = docs.find((d) => d.id === `${section}/readme`);
const children = sortDocs(
  docs.filter((d) => sectionOf(d.id) === section && !isSectionReadme(d.id)).map((d) => d.id)
);
const entryFor = (id: string) => docs.find((d) => d.id === id)!;
const rendered = readme ? await render(readme) : null;
const navDocs = docs.map((d) => ({ id: d.id, title: extractTitle(d.body ?? '', d.id) }));
const widgets = SECTION_WIDGETS[section] ?? [];
const tools = SECTION_TOOLS[section] ?? [];
---
<BaseLayout title={sectionTitle(section)}>
  <Sidebar slot="sidebar" docs={navDocs} currentSection={section} />
  <div class="section-page">
    <article class="prose">
      {readme?.data.status === 'updating' && <StatusBanner />}
      {rendered ? <rendered.Content /> : <h1>{sectionTitle(section)}</h1>}
    </article>
    {widgets.length > 0 && (
      <section class="widgets" aria-label="Interactive visualizations">
        <h2 class="docs-heading">Interactive</h2>
        {widgets.map((w) => (
          <div class="widget-frame">
            <h3 class="widget-frame-title">{w.title}</h3>
            <p class="widget-frame-desc">{w.description}</p>
            <WidgetHost client:visible widgetId={w.id} />
          </div>
        ))}
      </section>
    )}
    {tools.length > 0 && (
      <section aria-label="Interactive tools">
        <h2 class="docs-heading">Tools</h2>
        {tools.map((t) => (
          <a class="tool-card" href={withBase(t.href)}>
            <h3 class="widget-frame-title">{t.title}</h3>
            <p class="widget-frame-desc">{t.description}</p>
          </a>
        ))}
      </section>
    )}
    <h2 class="docs-heading">Study materials</h2>
    <ul class="doc-list">
      {children.map((id) => {
        const e = entryFor(id);
        const iso = e.filePath ? getLastCommitISO(e.filePath) : null;
        return (
          <li>
            <a href={withBase(`/${id}/`)}>{extractTitle(e.body ?? '', e.id)}</a>
            <FreshnessBadge iso={iso} uid={id} />
          </li>
        );
      })}
    </ul>
  </div>
</BaseLayout>

<style>
  .section-page { max-width: var(--content-width); margin: 0 auto; }
  .docs-heading {
    margin-top: 2.5rem; font-size: 0.82rem; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted);
    display: flex; align-items: center; gap: 0.75rem;
  }
  .docs-heading::after { content: ''; flex: 1; border-top: 2px dashed var(--border); }
  .doc-list { list-style: none; padding: 0; display: grid; gap: 0.5rem; }
  .doc-list li {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    border: 1px solid var(--border); border-radius: var(--radius);
    padding: 0.7rem 1rem; background: var(--surface);
    transition: border-color 120ms ease;
  }
  .doc-list li:hover { border-color: var(--accent); }
  @media (max-width: 600px) {
    .doc-list li { flex-direction: column; align-items: flex-start; gap: 0.4rem; padding: 0.6rem 0.8rem; }
  }
</style>
