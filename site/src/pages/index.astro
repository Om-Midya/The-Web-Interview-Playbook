---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionCard from '../components/SectionCard.astro';
import { sectionOf, sectionTitle, extractTitle, isSectionReadme, allSectionDirs } from '../lib/content';
import { getLastCommitISO, isRecent, formatDate } from '../lib/freshness';

const docs = await getCollection('docs');
const sections = allSectionDirs(docs.map((d) => d.id));

const withDates = docs
  .filter((d) => d.id !== 'readme' && !isSectionReadme(d.id))
  .map((d) => ({ d, iso: d.filePath ? getLastCommitISO(d.filePath) : null }))
  .filter((x) => x.iso);
const recentFeed = withDates
  .sort((a, b) => Date.parse(b.iso!) - Date.parse(a.iso!))
  .slice(0, 5);

const sectionMeta = sections.map((s) => {
  const children = docs.filter((d) => sectionOf(d.id) === s && !isSectionReadme(d.id));
  const fresh = children.some((d) => d.filePath && isRecent(getLastCommitISO(d.filePath)));
  return { dir: s, title: sectionTitle(s), docCount: children.length, fresh };
});
---
<BaseLayout title="Home">
  <div class="home">
    <section class="hero">
      <p class="eyebrow">Web Interview Playbook</p>
      <h1>Prepare the way interviewers <em>expect you to think</em>.</h1>
      <p class="lede">
        Interactive roadmaps, visualized concepts, and {docs.length}+ docs of questions,
        answers, and mock interviews for web development interviews.
      </p>
      <a class="cta" href="/roadmap/">Start with the roadmap →</a>
    </section>

    <section>
      <h2>Sections</h2>
      <div class="grid">
        {sectionMeta.map((m) => <SectionCard {...m} />)}
      </div>
    </section>

    <section>
      <h2>Recently updated</h2>
      <ul class="feed">
        {recentFeed.map(({ d, iso }) => (
          <li>
            <a href={`/${d.id}/`}>{extractTitle(d.body ?? '', d.id)}</a>
            <time>{formatDate(iso!)}</time>
          </li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .home { max-width: 960px; margin: 0 auto; display: grid; gap: 3.5rem; }

  .hero { padding: 3.5rem 0 1.25rem; max-width: 40rem; }
  .eyebrow {
    font-family: var(--font-mono); font-size: 0.78rem; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent);
    margin: 0 0 0.9rem;
  }
  .hero h1 {
    font-size: clamp(2rem, 4.2vw, 2.75rem); line-height: 1.12; letter-spacing: -0.03em;
    margin: 0 0 1.1rem;
  }
  .hero em { color: var(--accent); font-style: normal; }
  .lede { color: var(--text-muted); font-size: 1.05rem; line-height: 1.6; }
  .cta {
    display: inline-block; margin-top: 0.9rem; background: var(--accent);
    color: var(--accent-contrast); border-radius: var(--radius); padding: 0.65rem 1.15rem;
    font-weight: 600; transition: filter 120ms ease, transform 120ms ease;
  }
  .cta:hover { text-decoration: none; filter: brightness(1.08); transform: translateY(-1px); }

  h2 {
    font-size: 0.85rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--text-muted); margin: 0 0 1rem;
  }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 0.9rem; }

  .feed { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.25rem; max-width: 40rem; }
  .feed li {
    display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;
    padding: 0.6rem 0; border-bottom: 1px solid var(--border);
  }
  .feed li:last-child { border-bottom: none; }
  .feed a { color: var(--text); font-weight: 500; }
  .feed a:hover { color: var(--accent); }
  .feed time { color: var(--text-muted); font-size: 0.85rem; white-space: nowrap; font-variant-numeric: tabular-nums; }
</style>
