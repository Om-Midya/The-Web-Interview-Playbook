---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import StarBuilder from '../widgets/star/StarBuilder';
import { parseBehavioralQuestions } from '../lib/prep';
import { extractTitle } from '../lib/content';
import { withBase } from '../lib/base';
import '../styles/widgets.css';

const docs = await getCollection('docs');
const qDoc = docs.find((d) => d.id === '09-hr-interviews/behavioral-questions');
const questions = qDoc ? parseBehavioralQuestions(qDoc.body ?? '') : [];
const navDocs = docs.map((d) => ({ id: d.id, title: extractTitle(d.body ?? '', d.id) }));
---
<BaseLayout title="STAR Answer Builder" description="Draft, map, and rehearse your STAR stories against the real timing budgets.">
  <Sidebar slot="sidebar" docs={navDocs} />
  <div class="tool-page">
    <p class="eyebrow">Behavioral prep</p>
    <h1 class="display tool-title">STAR Answer Builder</h1>
    <p class="lede">
      One story answers many questions. Draft against the 75-second clock, map your coverage,
      export your bank — everything stays in your browser.
      Based on <a href={withBase('/09-hr-interviews/behavioral-questions/')}>the behavioral question bank</a>.
    </p>
    {questions.length > 0 ? (
      <StarBuilder client:load questions={questions} />
    ) : (
      <p>The question bank could not be parsed — read <a href={withBase('/09-hr-interviews/behavioral-questions/')}>the source document</a>.</p>
    )}
  </div>
</BaseLayout>

<style>
  .tool-page { max-width: 62rem; margin: 0 auto; }
  .eyebrow {
    font-family: var(--font-mono); font-size: 0.78rem; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent-2);
    margin: 0 0 0.5rem;
  }
  .tool-title { font-size: clamp(1.7rem, 3.4vw, 2.4rem); margin-bottom: 0.75rem; }
  .lede { color: var(--text-muted); max-width: 62ch; }
</style>
